# ============================================================
# Template de variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS commiter le fichier .env
# ============================================================

# ────────────────────────────────────────────────
# Serveur
# ────────────────────────────────────────────────
NODE_ENV=development
PORT_BACKEND=3001
PORT_FRONTEND=3000

# ────────────────────────────────────────────────
# Base de données PostgreSQL
# ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=my_database
DB_USER=my_user
DB_PASSWORD=my_password

# ────────────────────────────────────────────────
# Authentification JWT
# ────────────────────────────────────────────────
JWT_SECRET=change_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ────────────────────────────────────────────────
# CORS & URLs
# ────────────────────────────────────────────────
ORIGIN_URL=http://localhost:3000
SERVER_URL=http://localhost:3001

# ────────────────────────────────────────────────
# Email (optionnel — pour reset de mot de passe)
# ────────────────────────────────────────────────
EMAIL=no-reply@monapp.fr
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ────────────────────────────────────────────────
# Ajoutez ici les variables spécifiques au projet
# ────────────────────────────────────────────────
